# =========================
# LLM provider
# =========================
# Selects the chat/completion provider used for paper metadata extraction,
# summary generation, and automatic paper-to-paper edge extraction.
# Options: gemini, upstage, openai.
LLM_PROVIDER=gemini

# Model name sent to the selected provider.
# Gemini examples: gemini-2.5-flash, gemini-2.5-pro
# Upstage examples: solar-pro3
# OpenAI examples: gpt-4.1-mini, gpt-4.1
LLM_MODEL=gemini-2.5-flash

# When true, requests JSON-formatted model output for stricter parsing.
# Keep this true unless a selected provider/model rejects JSON response format.
LLM_RESPONSE_FORMAT_JSON=true

# Maximum PDF upload size accepted by the app routes, in megabytes.
MAX_UPLOAD_MB=20

# Optional. Project id used when a request does not specify one
# (e.g. the Google OAuth start route). Defaults to "demo-project" when unset.
# DEFAULT_PROJECT_ID=demo-project

# Gemini through the OpenAI-compatible Google AI Studio API.
# Get this from Google AI Studio. Never commit real keys.
GEMINI_API_KEY=

# OpenAI-compatible Gemini endpoint. Change only if Google changes the API path
# or if you intentionally route through a compatible proxy.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Upstage Solar Chat API. Used when LLM_PROVIDER=upstage.
UPSTAGE_API_KEY=

# Upstage OpenAI-compatible chat endpoint.
UPSTAGE_BASE_URL=https://api.upstage.ai/v1

# Optional OpenAI fallback/comparison. Used when LLM_PROVIDER=openai.
OPENAI_API_KEY=

# OpenAI-compatible endpoint for OpenAI or an OpenAI-compatible proxy.
OPENAI_BASE_URL=https://api.openai.com/v1

# =========================
# PDF text extraction
# =========================
# Selects how PDF text is extracted before the LLM sees the paper.
# Options:
# - local: use pdf-parse inside the server process.
# - upstage: use Upstage Document Parse, better for OCR/scanned/layout-heavy PDFs.
PDF_TEXT_PROVIDER=upstage

# If true, the app falls back to local pdf-parse when Upstage Document Parse
# fails. Useful during development and for provider outages.
PDF_TEXT_FALLBACK_TO_LOCAL=true

# Upstage Document Parse endpoint. Used only when PDF_TEXT_PROVIDER=upstage.
UPSTAGE_DOCUMENT_PARSE_URL=https://api.upstage.ai/v1/document-digitization

# Upstage document parsing model name.
UPSTAGE_DOCUMENT_PARSE_MODEL=document-parse

# OCR mode for Upstage Document Parse.
# Common values: auto, force. Use force for scanned PDFs when needed.
UPSTAGE_DOCUMENT_PARSE_OCR=auto

# Optional output format hint for Upstage Document Parse.
# Leave empty to use the provider default. Common value: markdown.
# UPSTAGE_DOCUMENT_PARSE_OUTPUT_FORMAT=markdown

# =========================
# Storage
# =========================
# Selects where graph.json, uploaded PDFs, and persisted project settings live.
# Options:
# - local: filesystem under LOCAL_STORAGE_ROOT.
# - google_drive: Google Drive project folder through OAuth.
STORAGE_BACKEND=local

# Root folder for local storage mode. This folder is local-only and ignored by git.
LOCAL_STORAGE_ROOT=./local_data

# =========================
# Google OAuth / Drive
# =========================
# OAuth client id from Google Cloud Console. Required for Google Drive mode.
GOOGLE_CLIENT_ID=

# OAuth client secret from Google Cloud Console. Required for Google Drive mode.
GOOGLE_CLIENT_SECRET=

# OAuth callback URL registered in Google Cloud Console.
# Local default: http://localhost:3000/api/auth/google/callback
# Production example: https://your-domain/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Local OAuth token/session store. Used when DATABASE_URL is empty.
# Keep this inside LOCAL_STORAGE_ROOT for local development.
GOOGLE_AUTH_FILE=./local_data/tokens/google-auth.json

# =========================
# Optional Postgres auth/session store for shared deployments
# =========================
# Postgres connection string for shared deployment OAuth/session storage.
# When unset, the app uses GOOGLE_AUTH_FILE instead.
# DATABASE_URL=postgresql://user:password@host:5432/db

# Set true when the deployment database requires SSL.
# DATABASE_SSL=true

# NOTE on Vercel + Neon:
# The Vercel <-> Neon integration auto-injects many variables into the
# deployment (DATABASE_URL_UNPOOLED, POSTGRES_URL, POSTGRES_URL_NON_POOLING,
# POSTGRES_PRISMA_URL, PGHOST, PGUSER, PGPASSWORD, PGDATABASE, NEON_PROJECT_ID,
# and so on). This app only reads DATABASE_URL and DATABASE_SSL, so you do NOT
# need to recreate the other Neon/Postgres variables for local development.

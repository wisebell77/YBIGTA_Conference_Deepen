OPENAI_API_KEY=
LLM_MODEL=gpt-4.1-mini
MAX_UPLOAD_MB=20

# local or google_drive. Use local while Google Drive auth is unavailable.
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=./local_data

# Google OAuth / Drive
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Local multi-user auth/session store. Used when DATABASE_URL is empty.
GOOGLE_AUTH_FILE=./local_data/tokens/google-auth.json

# Optional Postgres auth/session store for shared deployments.
# DATABASE_URL=postgresql://user:password@host:5432/db
# DATABASE_SSL=true
